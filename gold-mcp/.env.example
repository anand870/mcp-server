# Gold Advisor MCP Server - Environment Variables

# API Keys (optional - providers without keys use free tiers or are skipped)
FREEGOLDAPI_KEY=
METALSDEV_KEY=
GOLDAPI_KEY=

# Database path override (optional, defaults to config.yaml)
# DATABASE_PATH=data/gold.db

# Config file path (optional)
# CONFIG_PATH=config.yaml

# Log level override (optional)
# LOG_LEVEL=INFO
